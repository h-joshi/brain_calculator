{
  "name": "brain-arcade",
  "private": true,
  "scripts": {
    "dev": "python3 -m http.server 8000",
    "check": "npm run check:html && npm run check:css && npm run check:js",
    "check:html": "html-validate index.html tilt-rally.html 'Brain Score Calculator.html'",
    "check:css": "stylelint tilt-rally.css",
    "check:js": "eslint tilt-rally.js supabase-config.js supabase-config.example.js tests",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@playwright/test": "1.54.1",
    "eslint": "9.31.0",
    "globals": "16.3.0",
    "html-validate": "10.2.1",
    "stylelint": "16.22.0",
    "stylelint-config-standard": "38.0.0"
  }
}
